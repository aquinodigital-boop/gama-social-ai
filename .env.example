# ======================================================
# Modo 1 — Chave client-side (dev local / power-user)
# ======================================================
# A chave vai para o bundle — usar só em desenvolvimento
# ou quando cada usuário configura a própria via Settings.
VITE_GEMINI_API_KEY=your_api_key_here

# ======================================================
# Modo 2 — Proxy serverless (produção recomendado)
# ======================================================
# Quando setado, o app passa a chamar /api/gemini e /api/imagen
# no lugar de falar direto com o Google. A chave fica no server.
#
# Setar estas duas no build (Vercel > Environment Variables):
# VITE_GEMINI_PROXY_URL=/api/gemini
# VITE_IMAGEN_PROXY_URL=/api/imagen
#
# E esta no servidor (sem prefixo VITE_, não vai pro bundle):
# GEMINI_API_KEY=your_server_side_key_here
#
# Opcional — allowlist de origens extras (CSV) para o proxy aceitar requests.
# Por padrão o proxy aceita same-origin (mesmo host do request) + localhost
# em dev. Use esta variável se o app chama o proxy de um domínio diferente.
# ALLOWED_ORIGINS=https://app.gama.com.br,https://staging.gama.com.br
